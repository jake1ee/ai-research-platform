# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose to frontend

# ── Database (direct Postgres – for SQLAlchemy/Alembic if needed) ─────────────
# Dashboard → Project Settings → Database → Connection string (Session mode)
DATABASE_URL=postgresql+psycopg2://postgres:password@db.your-project-ref.supabase.co:5432/postgres
# SQLite for local dev without Supabase:
# DATABASE_URL=sqlite:///./modelcompare.db

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── LLM provider API keys ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-actual-openai-key-here
ANTHROPIC_API_KEY=sk-your-actual-anthropic-key-here
GEMINI_API_KEY=your-actual-gemini-key-here
COHERE_API_KEY=your-actual-cohere-key-here

# ── LLM settings ──────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=60
DEFAULT_JUDGE_MODEL=gpt-4o

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CACHE_TTL_SECONDS=3600

# ── Plan rate limits (evaluations per month) ──────────────────────────────────
FREE_EVAL_LIMIT=100
PRO_EVAL_LIMIT=10000
ENTERPRISE_EVAL_LIMIT=-1  # -1 = unlimited
